# PORT=8000
# NODE_ENV=production
# MONGO_URI=mongodb://localhost:27017/
# DB_NAME=HomeCare
# JWT_SECRET_KEY=change-this-access-secret
# JWT_REFRESH_SECRET_KEY=change-this-refresh-secret
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-this-password
# FRONTEND_URL=https://your-frontend-domain.onrender.com

# Twilio Verify OTP setup.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=

# Optional Fast2SMS fallback. If no SMS provider is configured, OTP is returned in the API response.
# FAST2SMS_API_KEY=

# Optional: force OTP to be returned even when SMS provider is configured.
# ALLOW_MOCK_OTP=true
