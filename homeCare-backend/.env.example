PORT=8000
NODE_ENV=production
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/
DB_NAME=HomeCare
JWT_SECRET_KEY=change-this-access-secret
JWT_REFRESH_SECRET_KEY=change-this-refresh-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
FRONTEND_URL=https://your-frontend-domain.onrender.com

# Use FAST2SMS_API_KEY in real production.
FAST2SMS_API_KEY=

# Set true only for demo/testing deployments where OTP should be returned in API response.
ALLOW_MOCK_OTP=false
